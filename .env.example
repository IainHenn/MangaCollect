# Example environment variables for MangaCollect
# Copy to .env and fill values before running `docker compose`.

# Database
DATABASE=postgres://user:pass@db:5432/mangacollect
HOST=0.0.0.0
PORT=8080
USER=postgres
PASSWORD=changeme

# App
SECRET_KEY=replace_me

# Email (optional)
EMAIL=you@example.com
EMAIL_PASSWORD=replace_me
SMTP=smtp.example.com
SMTP_PORT=587
USE_TLS=true
APP_PASSWORD=replace_me
FRONTEND_URL=http://localhost:3000

# AWS (optional)
AWS_REGION=us-east-1
AWS_BUCKET_NAME=your-bucket-name
